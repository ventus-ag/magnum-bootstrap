# Template for the magnum-e2e tool's OpenStack credentials + run config.
# Copy to .env (gitignored) and fill in. Load before running:
#
#   cp .env.example .env && $EDITOR .env
#   set -a; . ./.env; set +a
#   go run ./e2e/cmd/magnum-e2e -preflight
#
# --- Auth: application credential (preferred) ---
OS_AUTH_URL=https://keystone.example:5000/v3
OS_REGION_NAME=
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3
#OS_APPLICATION_CREDENTIAL_ID=
#OS_APPLICATION_CREDENTIAL_SECRET=
#
# --- …or user/password (full split-domain RC is honoured) ---
OS_USERNAME=
OS_PASSWORD=
OS_USER_DOMAIN_NAME=
# Scope by project ID (preferred; used alone) …
OS_PROJECT_ID=
# … or by name + its domain:
#OS_PROJECT_NAME=
#OS_PROJECT_DOMAIN_ID=
#OS_PROJECT_DOMAIN_NAME=

# --- Magnum run config ---
# Version-pinned templates: the k8s version comes from the template, not a label.
CLUSTER_TEMPLATE=
UPGRADE_TEMPLATE=
# Optional: a pre-existing nova keypair. If unset, the tool auto-creates an
# ephemeral one and deletes it at teardown.
#KEYPAIR=
# Deliver the reconciler to nodes by staging the local build into Swift:
#BOOTSTRAP_BINARY=dist/bootstrap
# …or point at a hosted binary instead:
#RECONCILER_VERSION=
#RECONCILER_BINARY_URL=
